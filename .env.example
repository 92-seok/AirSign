# =====================================================
# AirSign - 환경 변수 템플릿 (실값은 .env로 복사 후 입력)
# 이 파일은 git에 추적됩니다. 실 비밀값을 절대 넣지 마세요.
# =====================================================

# ---------- DB (NestJS / API) ----------
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_CHARSET=utf8mb4

# ---------- JWT / 인증 ----------
JWT_SECRET=please-change-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---------- API 서버 (NestJS) ----------
API_PORT=3001
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api

# ---------- 외부 장비 통신 ----------
DEVICE_HTTP_TIMEOUT_MS=60000
DEVICE_HTTP_CONNECT_TIMEOUT_MS=10000
EXTERNAL_ACK_URL=

# ---------- 권한 (전체 조회 가능한 슈퍼 RootID) ----------
SUPER_ROOT_ID=

# ---------- 파일 업로드 ----------
UPLOAD_MAX_SIZE_MB=40
UPLOAD_DIR_VIDEO=./uploads/video
UPLOAD_DIR_IMAGE=./uploads/image

# ---------- 프론트엔드 (Next.js) ----------
# NEXT_PUBLIC_API_URL은 비워두면 same-origin /api 사용 (rewrites가 NestJS로 프록시)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_DAUM_POSTCODE_KEY=

# ---------- 시간대 ----------
TZ=Asia/Seoul
